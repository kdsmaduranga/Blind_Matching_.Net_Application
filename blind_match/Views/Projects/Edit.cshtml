@model ProjectApprovalSystem.Models.Project
@{
    ViewData["Title"] = "Edit Proposal";
}
<h1 class="mb-4">Edit Project Proposal</h1>
<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" enctype="multipart/form-data" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-floating mb-3">
                <input asp-for="Title" class="form-control" placeholder="Title" />
                <label asp-for="Title"></label>
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="Abstract" class="form-control" placeholder="Abstract" style="height:120px"></textarea>
                <label asp-for="Abstract"></label>
                <span asp-validation-for="Abstract" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="TechnicalStack" class="form-control" placeholder="Tech Stack" />
                <label asp-for="TechnicalStack"></label>
                <span asp-validation-for="TechnicalStack" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <select asp-for="ResearchAreaId" class="form-select" asp-items="ViewBag.ResearchAreaId"></select>
                <label asp-for="ResearchAreaId">Research Area</label>
                <span asp-validation-for="ResearchAreaId" class="text-danger"></span>
            </div>

            @if (!string.IsNullOrEmpty(Model.ProposalFile))
            {
                <div class="mb-3">
                    <label class="form-label">Current Proposal File:</label>
                    <a href="@Model.ProposalFile" target="_blank" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-file-pdf me-1"></i>View Current PDF
                    </a>
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Replace Proposal Document (optional)</label>
                <input type="file" name="proposalFile" class="form-control" accept=".pdf" />
                <small class="text-muted">Upload a new PDF to replace the existing one.</small>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-2"></i>Save Changes
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}