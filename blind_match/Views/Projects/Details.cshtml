@model ProjectApprovalSystem.Models.Project
@{
    ViewData["Title"] = "Project Details";
    var supervisor = ViewBag.Supervisor as ApplicationUser;
}
<h1 class="mb-4">Project Details</h1>
<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Abstract</dt>
            <dd class="col-sm-9">@Model.Abstract</dd>

            <dt class="col-sm-3">Technical Stack</dt>
            <dd class="col-sm-9">@Model.TechnicalStack</dd>

            <dt class="col-sm-3">Research Area</dt>
            <dd class="col-sm-9">@Model.ResearchArea?.Name</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Status == "Matched" ? "bg-success" : "bg-warning")">@Model.Status</span>
            </dd>

            @if (!string.IsNullOrEmpty(Model.ProposalFile))
            {
                <dt class="col-sm-3">Proposal Document</dt>
                <dd class="col-sm-9">
                    <a href="@Model.ProposalFile" target="_blank" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-file-pdf me-1"></i>View PDF
                    </a>
                </dd>
            }

            @if (User.IsInRole("Student") && Model.Status == "Matched" && supervisor != null)
            {
                <dt class="col-sm-3">Matched Supervisor</dt>
                <dd class="col-sm-9">
                    <strong>@supervisor.FullName</strong><br />
                    Email: <a href="mailto:@supervisor.Email">@supervisor.Email</a>
                </dd>
            }
        </dl>

        <div>
            @if (User.IsInRole("Student") && Model.Status == "Pending")
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="fas fa-edit me-1"></i>Edit
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                    <i class="fas fa-trash me-1"></i>Withdraw
                </a>
            }
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>