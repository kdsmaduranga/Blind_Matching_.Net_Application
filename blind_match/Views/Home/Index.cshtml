@using Microsoft.AspNetCore.Identity
@using ProjectApprovalSystem.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Home";
}
<div class="hero text-center">
    <div class="float-animation">
        <i class="fas fa-user-secret fa-5x mb-4" style="color: var(--primary);"></i>
    </div>
    <h1 class="display-4 fw-bold mb-3">BlindMatch PAS</h1>
    <p class="lead mb-4" style="color: var(--text-secondary);">Fair, transparent project-to-supervisor matching.</p>
    @if (!SignInManager.IsSignedIn(User))
    {
        <div class="mt-4">
            <a class="btn btn-primary btn-lg px-4 me-3" href="/Identity/Account/Register"><i class="fas fa-user-plus me-2"></i>Get Started</a>
            <a class="btn btn-outline-secondary btn-lg px-4" href="/Identity/Account/Login"><i class="fas fa-sign-in-alt me-2"></i>Login</a>
        </div>
    }
    else
    {
        var user = await UserManager.GetUserAsync(User);
        var roles = user != null ? await UserManager.GetRolesAsync(user) : new List<string>();
        bool profileIncomplete = string.IsNullOrEmpty(user?.FullName) || roles.Count == 0;
        if (profileIncomplete)
        {
            <div class="alert alert-warning mt-4 d-inline-block"><i class="fas fa-exclamation-triangle me-2"></i>Profile incomplete! <a href="/CompleteProfile" class="alert-link fw-bold">Click here to complete it</a>.</div>
        }
        <div class="mt-4">
            <p class="text-success mb-3">Welcome back, <strong>@(user?.FullName ?? User.Identity?.Name)</strong>!</p>
            @if (User.IsInRole("Student"))
            {
                <a class="btn btn-primary btn-lg" asp-controller="Projects" asp-action="Create"><i class="fas fa-plus-circle me-2"></i>Submit New Proposal</a>
            }
            else if (User.IsInRole("Supervisor"))
            {

                <a class="btn btn-primary btn-lg" asp-controller="Projects" asp-action="BlindReview"><i class="fas fa-eye-slash me-2"></i>Start Blind Review</a>
            }
            else if (User.IsInRole("ModuleLeader") || User.IsInRole("SystemAdmin"))
            {

                <a class="btn btn-primary btn-lg" asp-controller="Coordinator" asp-action="Index"><i class="fas fa-cog me-2"></i>Admin Dashboard</a>
            }
        </div>
    }
</div>
<div class="row mt-5 g-4">
    <div class="col-md-4"><div class="card h-100"><div class="card-body text-center p-4"><div class="mb-3"><i class="fas fa-file-alt fa-3x" style="color: var(--primary);"></i></div><h5 class="card-title fw-bold">Submit Ideas</h5><p class="card-text">Students submit project proposals anonymously.</p></div></div></div>
    <div class="col-md-4"><div class="card h-100"><div class="card-body text-center p-4"><div class="mb-3"><i class="fas fa-search fa-3x" style="color: var(--secondary);"></i></div><h5 class="card-title fw-bold">Blind Review</h5><p class="card-text">Supervisors browse projects without knowing student identities.</p></div></div></div>
    <div class="col-md-4"><div class="card h-100"><div class="card-body text-center p-4"><div class="mb-3"><i class="fas fa-handshake fa-3x" style="color: var(--accent);"></i></div><h5 class="card-title fw-bold">Perfect Match</h5><p class="card-text">Identities revealed after match confirmation.</p></div></div></div>
</div>