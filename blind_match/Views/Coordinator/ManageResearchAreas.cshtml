@model IEnumerable<ProjectApprovalSystem.Models.ResearchArea>

@{
    ViewData["Title"] = "Manage Research Areas";
}

<h1>Manage Research Areas</h1>
<p>
    <a asp-action="CreateResearchArea" class="btn btn-primary">Add New Area</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>
                    <a asp-action="EditResearchArea" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="DeleteResearchArea" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>