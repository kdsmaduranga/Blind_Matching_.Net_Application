@model IEnumerable<ProjectApprovalSystem.Models.Match>
@{
    ViewData["Title"] = "Coordinator Dashboard";
}
<h1 class="mb-4">All Matches</h1>
<table class="table">
    <thead><tr><th>Project</th><th>Student</th><th>Supervisor</th><th>Date</th></tr></thead>
    <tbody>@foreach (var m in Model) {
    <tr><td>@m.Project.Title</td><td>@m.Project.Student?.FullName</td><td>@m.Supervisor?.FullName</td><td>@m.MatchDate.ToShortDateString()</td></tr>
        }
</tbody>
</table>